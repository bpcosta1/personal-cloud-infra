# TRAEFIK & PORTAINER CONFIGURATION
# Copy this file to .env and fill in your actual data.

# The email address used for Let's Encrypt SSL certificate registration/notifications
ACME_EMAIL=admin@your-domain.com

# Your base domain name (e.g., example.com)
# Portainer will automatically be routed to portainer.example.com
DOMAIN=your-base-domain.com

# Cloudflare API Token for DNS Challenge
# IMPORTANT: This token needs "Zone:DNS:Edit" permissions.
# Generate it here: https://dash.cloudflare.com/profile/api-tokens
CF_DNS_API_TOKEN=your_cloudflare_dns_api_token_here_xxxxxx
